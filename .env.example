# ── AWS / S3 ──────────────────────────────────────────────────────────────────
# Use real AWS credentials for production, or leave defaults for local MinIO.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# ── S3 Bucket ─────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=pixel-pipeline

# ── S3 Endpoint ───────────────────────────────────────────────────────────────
# Local development (MinIO via Docker):  http://localhost:9000
# Inside Docker Compose network:         http://minio:9000   ← set by compose
# AWS S3 production:                     leave blank
S3_ENDPOINT_URL=http://localhost:9000
